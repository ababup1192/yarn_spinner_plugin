}, "line:5a5776a0": { "text": "ぼく: もしかして、あの 金庫の 合言葉 かも しれない。" }, "line:cc6771d7": { "text": "ぼく: 何かの 暗号 だろうか。" }, "line:6ff21549": { "text": "ぼく: とりあえず 覚えておこう。" }, "line:a0d9db11": { "text": "ぼく: 額縁の 紙には 「△　×　○」と 書かれている。" }, "line:cc11fc7e": { "text": "ぼく: 古びた 金庫だ。" }, "line:5a21fb09": { "text": "ぼく: ３つの 記号を 合わせる ダイヤルが ついている。" }, "line:cb3c4499": { "text": "合わせてみる" }, "line:5d0c43ee": { "text": "やめておく" }, "line:b885848e": { "text": "ぼく: …今は やめておこう。" }, "line:99487d6b": { "text": "ぼく: １つ目の しるしは…" }, "line:231974f2": { "text": "△" }, "line:b5297385": { "text": "○" }, "line:16bc171b": { "text": "×" }, "line:d932566e": { "text": "ぼく: ２つ目の しるしは…" }, "line:63635ff7": { "text": "△" }, "line:f5535880": { "text": "○" }, "line:644ee710": { "text": "×" }, "line:c5142266": { "text": "ぼく: ３つ目の しるしは…" }, "line:a63abf50": { "text": "△" }, "line:300ab827": { "text": "○" }, "line:8a5bb1be": { "text": "×" }, "line:a3970ccb": { "text": "カチャリ。" }, "line:00026855": { "text": "金庫が ゆっくりと 開く。" }, "line:96326f22": { "text": "中には 古びた 鍵が 入っていた。" }, "line:2c6366bb": { "text": "ぼく: これだ！" }, "line:ba5361cc": { "text": "ぼく: あの ドアを 開けられる かも しれない。" }, "line:2b4ede5c": { "text": "ぼく: インベントリから 鍵を 選んで、" }, "line:bd7ed92b": { "text": "ドアに 使ってみよう。" }, "line:887d26d0": { "text": "ガチャッ。" }, "line:1e4d21a7": { "text": "ぼく: …違う ようだ。" }, "line:a41c283e": { "text": "ぼく: もう一度 額縁の 記号を 確かめよう。" }, "line:322c2f49": { "text": "ぼく: ヒントは どこかに あるはずだ。" }, "line:91b94bd7": { "text": "ぼく: そもそも 何か 手がかりは ないだろうか。" }, "line:e4e610a0": { "text": "ぼく: 金庫は すでに 開いている。中は 空だ。" }, "line:36f13ff4": { "text": "ぼく: 鍵穴が ある。" }, "line:a0c13883": { "text": "ぼく: 持っている 鍵が 使えそうだ。" }, "line:31dc8713": { "text": "ぼく: インベントリから 鍵を 選択しよう。" }, "line:dc860c52": { "text": "ドアを 引いてみたが、" }, "line:bb6dfd00": { "text": "ガチャガチャと 鳴るだけだ。" }, "line:2d5dfa77": { "text": "ぼく: 鍵が かかっている。" }, "line:970cf3ee": { "text": "ぼく: 何度 試しても 同じだ。" }, "line:013cf499": { "text": "ぼく: あの 金庫を 開ける 方法を 探そう。" }, "line:a2a99007": { "text": "ぼく: 引き出しの メモには 金庫の こと…" }, "line:34999770": { "text": "ぼく: 合言葉さえ わかれば 開ける はずだ。" }, "line:8ec89ee9": { "text": "ぼく: 部屋の 中に 何か 手がかりが あるはずだ。" }, "line:6f603432": { "text": "ぼく: この 鍵で 開けてみよう。" }, "line:fe7d8ba2": { "text": "カチャリ。" }, "line:684d8cd5": { "text": "鍵が 回り、ドアが ゆっくりと 解放された。" }, "line:8dc44bb5": { "text": "ぼく: 開いた！" }, "line:1bf44cc2": { "text": "部屋を 出る" }, "line:a1a5455b": { "text": "もう少し 残る" }, "line:3795422c": { "text": "ぼく: せっかくだ、もう少し 部屋を 見てから 出よう。" }, "line:aba9c3ce": { "text": "ドアは 既に 開け 放たれている。" }, "line:3d99c4b9": { "text": "部屋を 出る" }, "line:87c8cd20": { "text": "まだ 残る" }, "line:11f8ca57": { "text": "ぼく: ……もう少しだけ。" }, "line:b8b8ee53": { "text": "ぼく: 外の 風が 心地よい…" }, "line:2e88e924": { "text": "ぼく: ようやく、自由だ。" }, "line:452cadda": { "text": "～ END ～" } }, "diagnostics": [ ] }